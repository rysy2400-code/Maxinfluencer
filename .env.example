# Copy to .env.local (local) or set machine env on Windows crawler VMs.
# Never commit real secrets. .env / .env.local are gitignored.

# Crawler deploy (deploy-crawler.ps1): work-live Redis (Upstash uses rediss://)
# CRAWLER_REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST:6379
# Or use REDIS_URL for the same value.

# Web：广告主登录 JWT（至少 16 字符随机串；生产必填）
# AUTH_JWT_SECRET=

# Cookie Secure：生产默认 true；本地 HTTP 可设为 0
# AUTH_COOKIE_SECURE=0
